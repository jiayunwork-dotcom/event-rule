# PostgreSQL Configuration
POSTGRES_DB=event_rule
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password_here

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-please-change-this-to-a-long-random-string

# Backend Configuration
BACKEND_PORT=3000
NODE_ENV=production

# SMTP Configuration (for email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=alerts@example.com

# Slack Webhook URL (for Slack notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/XXX/XXX

# WeChat Work Webhook URL (for WeChat notifications)
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-wechat-key

# System Configuration
MAX_QUEUE_SIZE=10000
SLIDING_WINDOW_INTERVAL=10000
MAX_RULES_PER_TENANT=100
MAX_EVENTS_PER_SECOND=1000
MAX_ACTIVE_ALERTS=500

# Redis Configuration (optional, defaults to redis://redis:6379)
# REDIS_URL=redis://redis:6379

# Database URL (optional, defaults to postgres connection from env vars)
# DATABASE_URL=postgres://postgres:password@postgres:5432/event_rule
